{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["bun-types"],
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "proto/**/*.ts", "proto/**/*.tsx"]
}
